# LATTICE secret naming convention.
#
# Every node's identity_secret is referenced in manifest.yaml as `env:VAR_NAME`.
# The actual hex values live in per-host .env files (never committed).
#
# Naming convention: {NODE_ID_UPPERCASE}_SECRET
#
# Required env vars by host:
#
# mac-mini/.env:
#   ADMIN_TOKEN              # RAVEN_MESH Core admin token
#   EDITH_SECRET             # EDITH node identity HMAC secret
#   ANTHROPIC_API_KEY        # for EDITH to call Claude
#
# coltons-mac/.env:
#   CONTROL_SECRET           # Control node identity HMAC secret
#   CORE_URL=http://100.109.10.50:8000   # Tailscale URL of Core on Mac mini
#
# Generate hex secrets with: python3 -c "import secrets; print(secrets.token_hex(16))"
# Or run scripts/bootstrap.sh which does this for you.
